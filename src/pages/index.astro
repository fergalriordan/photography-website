---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from "../data/site";
import {
  WIDESCREEN_HOMEPAGE_CAROUSEL_PHOTOS,
  NARROW_SCREEN_HOMEPAGE_CAROUSEL_PHOTOS,
  HOMEPAGE_COLLAGE_HERO_PHOTOS,
  ADDITIONAL_HOMEPAGE_COLLAGE_PHOTOS,
} from "../data/homepage";

import PhotoCarousel from "../components/PhotoCarousel.astro";
import PhotoCollage from "../components/PhotoCollage.astro";

// Tiny blurred previews (~120 bytes) of the first hero slide, shown behind the
// carousel until the full image paints. Generated with Sharp from the first
// wide/narrow hero images; regenerate if those change.
const HERO_PLACEHOLDER_DESKTOP =
  "data:image/webp;base64,UklGRnAAAABXRUJQVlA4IGQAAAAwBACdASoYAA4APu1orU2ppqSiMAgBMB2JQBdgBEPpnbMnROIiuVu/ZoAA/slck3TSdCaGVY08qNZhcbbuxehhL64Ef5tZSyiKfx921A70JowlIzO4ibcX2NfuLwy1RP0MEAAA";
const HERO_PLACEHOLDER_MOBILE =
  "data:image/webp;base64,UklGRnIAAABXRUJQVlA4IGYAAAAwBACdASoYACQAPulgpU2pJaMiMAqpIB0JZQDDZ6HESy7n93UfsVI6bAAA/vBIYiyaEUp0PgYIUjGxqK+3KzsyYeOiqk1D/IB3R7MXM06HTKdvYhmxKmiYAwH1WqGinMC7ym5gAAA=";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${SITE_TITLE} | ${SITE_TAGLINE}`}
      description={SITE_DESCRIPTION}
    />
    <!--
      Preload the first hero image so it starts downloading during HTML parse
      instead of after the carousel <img> is discovered in the body. Two links
      mirror the wide/narrow <source> split in PhotoCarousel.astro.
    -->
    <link
      rel="preload"
      as="image"
      href={WIDESCREEN_HOMEPAGE_CAROUSEL_PHOTOS[0].src}
      media="(min-width: 768px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={NARROW_SCREEN_HOMEPAGE_CAROUSEL_PHOTOS[0].src}
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <style>
      .hero-fade-in {
        animation: heroFadeIn 1s ease both;
      }
      @keyframes heroFadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      .scroll-reveal {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 0.75s ease, transform 0.75s ease;
      }
      .scroll-reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="bg-background pt-16">
      <div class="hero-fade-in">
        <PhotoCarousel
          images={WIDESCREEN_HOMEPAGE_CAROUSEL_PHOTOS}
          mobileImages={NARROW_SCREEN_HOMEPAGE_CAROUSEL_PHOTOS}
          alt="Hero image"
          overlayText="Travel, nature and film photography — across Europe, the Americas, Africa, and beyond."
          placeholderDesktop={HERO_PLACEHOLDER_DESKTOP}
          placeholderMobile={HERO_PLACEHOLDER_MOBILE}
        />
      </div>

      <div class="scroll-reveal">
        <div class="px-5 pt-6 pb-3 border-t border-gray-light">
          <span class="text-sm tracking-[0.3em] uppercase text-gray">Selected Work</span>
        </div>
        <PhotoCollage
          photosEager={HOMEPAGE_COLLAGE_HERO_PHOTOS}
          photosLazy={ADDITIONAL_HOMEPAGE_COLLAGE_PHOTOS}
        />
      </div>
    </main>
    <Footer />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.05 }
      );
      document.querySelectorAll('.scroll-reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
