---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from "../data/site";
import {
  WIDESCREEN_HOMEPAGE_CAROUSEL_PHOTOS,
  NARROW_SCREEN_HOMEPAGE_CAROUSEL_PHOTOS,
  HOMEPAGE_COLLAGE_HERO_PHOTOS,
  ADDITIONAL_HOMEPAGE_COLLAGE_PHOTOS,
} from "../data/homepage";

import PhotoCarousel from "../components/PhotoCarousel.astro";
import PhotoCollage from "../components/PhotoCollage.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${SITE_TITLE} | ${SITE_TAGLINE}`}
      description={SITE_DESCRIPTION}
    />
    <style>
      html {
        scroll-snap-type: y proximity;
      }
      .snap-start {
        scroll-snap-align: start;
        scroll-margin-top: 64px;
        scroll-snap-stop: normal;
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="bg-background pt-16">
      <div class="snap-start">
        <PhotoCarousel
          images={WIDESCREEN_HOMEPAGE_CAROUSEL_PHOTOS}
          mobileImages={NARROW_SCREEN_HOMEPAGE_CAROUSEL_PHOTOS}
          alt="Hero image"
          overlayText="Travel, nature and film photography - in Europe, South America, Africa, and more."
        />
      </div>

      <div class="snap-start">
        <div class="px-5 pt-6 pb-3 border-t border-gray-light">
          <span class="text-[0.65rem] tracking-[0.3em] uppercase text-gray">Selected Work</span>
        </div>
        <PhotoCollage
          photosEager={HOMEPAGE_COLLAGE_HERO_PHOTOS}
          photosLazy={ADDITIONAL_HOMEPAGE_COLLAGE_PHOTOS}
        />
      </div>
    </main>
    <Footer />
  </body>
</html>
