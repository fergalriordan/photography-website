---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { galleries } from "../../data/galleries";

export async function getStaticPaths() {
  return galleries.map((gallery) => ({
    params: { slug: gallery.slug },
  }));
}

const { slug } = Astro.params;
const gallery = galleries.find((g) => g.slug === slug);

if (!gallery) {
  throw new Error(`Gallery not found: ${slug}`);
}
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={gallery.title} description={gallery.description.join(' ')} />
  </head>
  <body class="bg-background pt-16">
    <Header />
    <main class="px-2 py-4">
      <h1 class="text-gray-dark text-lg md:text-3xl mb-4 text-center">
        {gallery.name}
      </h1>

      <hr class="border-t border-gray-light mb-6 w-2/3 mx-auto" />

      {gallery.description.map((paragraph) => (
        <p class="text-gray text-xs md:text-base mb-4 px-4 md:px-20 text-center">
            {paragraph}
        </p>
        ))}

      <hr class="border-t border-gray-light mb-6 w-2/3 mx-auto" />

      <div class="masonry-galleries">
        {gallery.photos.map((photo, i) => (
          <img
            src={photo.src}
            alt={photo.alt || `Photo ${i + 1}`}
            loading={i < 3 ? "eager" : "lazy"}
            decoding="async"
            width={photo.width}
            height={photo.height}
            data-w={photo.width}
            data-h={photo.height}
            class="w-full block"
          />
        ))}
      </div>
    </main>

    <Footer />

    <style is:global>
      .masonry-galleries img {
        cursor: pointer;
        transition: filter 0.2s ease;
      }
      .masonry-galleries img:hover {
        filter: brightness(0.88);
      }

      #lightbox {
        position: fixed;
        inset: 0;
        background: rgba(20, 20, 20, 0.95);
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
      }
      #lightbox.active {
        opacity: 1;
        pointer-events: all;
      }
      .lightbox-container {
        position: absolute;
        inset: 0;
        overflow: hidden;
      }
      .lightbox-track {
        display: flex;
        width: 300%;
        height: 100%;
        transform: translateX(-33.333%);
        will-change: transform;
      }
      .lightbox-slide {
        width: 33.333%;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .lightbox-img {
        max-width: 90%;
        max-height: calc(90vh - 2rem);
        object-fit: contain;
        display: block;
      }
      .lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1.25rem;
        background: none;
        border: none;
        color: #d9d9d9;
        font-size: 2rem;
        line-height: 1;
        cursor: pointer;
        padding: 0.25rem 0.5rem;
        transition: color 0.15s ease;
      }
      .lightbox-close:hover {
        color: #ffffff;
      }
      .lightbox-prev,
      .lightbox-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #5f7a8e;
        font-size: 3.5rem;
        line-height: 1;
        cursor: pointer;
        padding: 0.5rem 1rem;
        transition: color 0.15s ease;
        user-select: none;
      }
      .lightbox-prev:hover,
      .lightbox-next:hover {
        color: #a0b1b8;
      }
      .lightbox-prev { left: 0.5rem; }
      .lightbox-next { right: 0.5rem; }
      @media (max-width: 767px) {
        .lightbox-prev,
        .lightbox-next {
          display: none;
        }
      }
      .lightbox-counter {
        position: absolute;
        bottom: 0.75rem;
        left: 50%;
        transform: translateX(-50%);
        color: #d9d9d9;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
      }
      .lightbox-counter.visible {
        opacity: 1;
      }
    </style>

    <script>
      import { initMasonry } from '../../scripts/masonry.ts';
      import { initLightbox } from '../../scripts/lightbox.ts';

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initMasonry();
          initLightbox();
        });
      } else {
        initMasonry();
        initLightbox();
      }
    </script>
  </body>
</html>
