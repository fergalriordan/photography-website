---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { galleries } from "../../data/galleries";

export async function getStaticPaths() {
  return galleries.map((gallery) => ({
    params: { slug: gallery.slug },
  }));
}

const { slug } = Astro.params;
const gallery = galleries.find((g) => g.slug === slug);

if (!gallery) {
  throw new Error(`Gallery not found: ${slug}`);
}
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={gallery.title} description={gallery.description.join(' ')} />
    <style>
      .header-fade-in {
        animation: headerFadeIn 0.9s ease both;
      }
      @keyframes headerFadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      .grid-fade-up {
        opacity: 0;
        transform: translateY(16px);
        animation: gridFadeUp 0.8s ease 0.3s both;
      }
      @keyframes gridFadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body class="bg-background pt-16">
    <Header />
    <main class="px-2 py-4">
      <div class="header-fade-in">
        <h1 class="text-gray-dark text-lg md:text-3xl tracking-[0.15em] mb-4 text-center">
          {gallery.name}
        </h1>

        <hr class="border-t border-gray-light mb-6 w-2/3 mx-auto" />

        {gallery.description.map((paragraph) => (
          <p class="text-gray text-xs md:text-base mb-4 px-4 md:px-20 text-center">
              {paragraph}
          </p>
          ))}

        <hr class="border-t border-gray-light mb-6 w-2/3 mx-auto" />
      </div>

      <div class="masonry-galleries grid-fade-up">
        {gallery.photos.map((photo, i) => (
          <img
            src={photo.src}
            alt={photo.alt || `Photo ${i + 1}`}
            loading={i < 3 ? "eager" : "lazy"}
            decoding="async"
            width={photo.width}
            height={photo.height}
            data-w={photo.width}
            data-h={photo.height}
            class="w-full block"
          />
        ))}
      </div>
    </main>

    <Footer />

    <style is:global>
      .masonry-galleries img {
        cursor: pointer;
        transition: filter 0.2s ease;
      }
      .masonry-galleries img:hover {
        filter: brightness(0.88);
      }
    </style>

    <script>
      import { initMasonry } from '../../scripts/masonry.ts';
      import { initLightbox } from '../../scripts/lightbox.ts';

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          initMasonry();
          initLightbox();
        });
      } else {
        initMasonry();
        initLightbox();
      }
    </script>
  </body>
</html>
