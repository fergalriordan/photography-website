---
interface ImageItem {
  src: string;
  alt?: string;
}

interface Props {
  images: ImageItem[];
  mobileImages: ImageItem[];
  alt?: string;
  overlayText?: string;
}

const props = Astro.props as Props;

const images = props.images ?? [];
const mobileImages = props.mobileImages ?? [];
const alt = props.alt ?? "";
const overlayText = props.overlayText;

const HEADER_HEIGHT = 64;

const slidePairs = images.map((desktop, i) => ({
  desktop,
  mobile: mobileImages[i],
}));
---

<section
  class="relative w-full overflow-hidden"
  style={`height: calc(100vh - ${HEADER_HEIGHT}px);`}
>
  <div class="relative w-full h-full group">
    {
      slidePairs.map(
        (pair: { desktop: ImageItem; mobile?: ImageItem }, index: number) => (
          <picture
            class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-700 ease-in-out ${
              index === 0 ? "opacity-100" : "opacity-0"
            }`}
            data-slide-index={index}
          >
            {pair.mobile && (
              <source srcset={pair.mobile.src} media="(max-width: 767px)" />
            )}
            <img
              src={pair.desktop?.src}
              alt={
                pair.desktop?.alt || pair.mobile?.alt || `${alt} ${index + 1}`
              }
              class="w-full h-full object-cover rounded-none"
              loading={index === 0 ? "eager" : "lazy"}
              fetchpriority={index === 0 ? "high" : "low"}
              decoding={index === 0 ? "sync" : "async"}
            />
          </picture>
        )
      )
    }

    <!-- Bottom gradient -->
    <div
      class="absolute inset-x-0 bottom-0 h-2/5 bg-gradient-to-t from-black/60 to-transparent pointer-events-none"
      aria-hidden="true"
    ></div>

    <!-- Text overlay -->
    {overlayText && (
      <div class="absolute bottom-14 left-8 md:left-12 max-w-xs md:max-w-sm pointer-events-none">
        <p class="inline-block bg-black/30 backdrop-blur-sm px-4 py-2 text-sm md:text-base text-white/90 font-light italic leading-relaxed">
          {overlayText}
        </p>
      </div>
    )}

    <!-- Indicators -->
    <div
      class="absolute bottom-5 left-1/2 transform -translate-x-1/2 flex space-x-2"
    >
      {
        slidePairs.map((_, index: number) => (
          <button
            class={`w-1.5 h-1.5 rounded-full bg-white/70 hover:bg-white transition-colors indicator-dot${
              index === 0 ? " active" : ""
            }`}
            aria-label={`Go to slide ${index + 1}`}
            data-indicator-index={index}
          />
        ))
      }
    </div>

    <!-- Arrows (appear on hover) -->
    <button
      type="button"
      class="absolute left-2 top-1/2 -translate-y-1/2 p-1 rounded-full bg-transparent hover:bg-white/20 transition-opacity transition-colors opacity-0 group-hover:opacity-100"
      aria-label="Previous slide"
      data-arrow="prev"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 text-white"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"
        ></path>
      </svg>
    </button>

    <button
      type="button"
      class="absolute right-2 top-1/2 -translate-y-1/2 p-1 rounded-full bg-transparent hover:bg-white/20 transition-opacity transition-colors opacity-0 group-hover:opacity-100"
      aria-label="Next slide"
      data-arrow="next"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 text-white"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
        ></path>
      </svg>
    </button>
  </div>
</section>

<script>
  import initPhotoCarousel from '../scripts/photoCarousel';
  initPhotoCarousel();
</script>