---
interface Photo {
  src: string;
  alt?: string;
  width: number;
  height: number;
}

const { photosEager = [] as Photo[], photosLazy = [] as Photo[] } = Astro.props;
---

<div class="bg-background px-5 pt-2">
  <div class="masonry-columns" id="photoGrid">
    {photosEager.map(({ src, alt, width, height }: Photo, i: number) => (
      <img
        src={src}
        alt={alt || `Photo ${i + 1}`}
        loading="eager"
        decoding="async"
        width={width}
        height={height}
        data-w={width}
        data-h={height}
        class="w-full block"
      />
    ))}
    {photosLazy.map(({ src, alt, width, height }: Photo, i: number) => (
      <img
        src={src}
        alt={alt || `Photo ${photosEager.length + i + 1}`}
        loading="lazy"
        decoding="async"
        width={width}
        height={height}
        data-w={width}
        data-h={height}
        class="w-full block"
        data-lazy="true"
        style="display: none"
      />
    ))}
  </div>
</div>

<div class="flex justify-center mt-6 pb-8">
  <button
    id="showMoreBtn"
    class="px-8 py-3 border border-gray-light text-[0.65rem] tracking-[0.25em] uppercase text-gray hover:border-gray hover:text-gray-dark transition-colors duration-200"
    aria-expanded="false"
    aria-controls="photoGrid"
  >
    Show More
  </button>
</div>

<script>
  import initPhotoCollage from '../scripts/photoCollage.ts';
  initPhotoCollage();
</script>
