---
import { galleries } from "../data/galleries";

interface Photo {
  src: string;
  alt?: string;
  width: number;
  height: number;
  gallery?: string;
}

const { photosEager = [] as Photo[], photosLazy = [] as Photo[] } = Astro.props;

// Each image is snapped to one of two fixed aspect ratios (landscape 3:2 /
// portrait 2:3) so the masonry packer deals with just two tile heights and can
// produce perfectly level columns. The source photos are already very close to
// these ratios, so the object-cover crop is minimal.
const orientation = (p: Photo) => (p.width >= p.height ? "landscape" : "portrait");

// Resolve a collage photo's `gallery` slug to the link label shown in the
// lightbox. Photos without a (known) gallery get no link — the lightbox keys
// off the presence of these data attributes.
const galleryLabels = new Map(
  galleries.map((g) => [g.slug, (g as { shortName?: string }).shortName ?? g.name])
);
const galleryLabel = (p: Photo) =>
  p.gallery ? galleryLabels.get(p.gallery) : undefined;
---

<div class="bg-background px-5 pt-2">
  <div class="collage-columns" id="photoGrid">
    {photosEager.map((photo: Photo, i: number) => (
      <img
        src={photo.src}
        alt={photo.alt || `Photo ${i + 1}`}
        loading="eager"
        decoding="async"
        class={`w-full block ${orientation(photo)}`}
        data-gallery-slug={galleryLabel(photo) ? photo.gallery : undefined}
        data-gallery-label={galleryLabel(photo)}
      />
    ))}
    {photosLazy.map((photo: Photo, i: number) => (
      <img
        src={photo.src}
        alt={photo.alt || `Photo ${photosEager.length + i + 1}`}
        loading="lazy"
        decoding="async"
        class={`w-full block ${orientation(photo)}`}
        data-lazy="true"
        data-gallery-slug={galleryLabel(photo) ? photo.gallery : undefined}
        data-gallery-label={galleryLabel(photo)}
        style="display: none"
      />
    ))}
  </div>
</div>

<div class="flex justify-center mt-6 pb-8">
  <button
    id="showMoreBtn"
    class="px-8 py-3 border border-gray-light text-[0.65rem] tracking-[0.25em] uppercase text-gray hover:border-gray hover:text-gray-dark transition-colors duration-200"
    aria-expanded="false"
    aria-controls="photoGrid"
  >
    Show More
  </button>
</div>

<style is:global>
  /* Before JS runs the images stack full-width (graceful fallback). */
  .collage-columns.cols-ready {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .collage-col {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .collage-columns img {
    width: 100%;
    display: block;
    object-fit: cover;
    cursor: pointer;
    transition: filter 0.2s ease;
  }
  .collage-columns img.landscape {
    aspect-ratio: 3 / 2;
  }
  .collage-columns img.portrait {
    aspect-ratio: 2 / 3;
  }
  .collage-columns img:hover {
    filter: brightness(0.88);
  }
</style>

<script>
  import initPhotoCollage from '../scripts/photoCollage.ts';
  initPhotoCollage();
</script>
